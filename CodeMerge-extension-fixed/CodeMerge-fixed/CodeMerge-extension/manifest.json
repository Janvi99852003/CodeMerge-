{
  "manifest_version": 3,
  "name": "CodeMerge — Daily Coding Tracker",
  "version": "3.1.0",
  "description": "Automatically track coding streaks across LeetCode, Codeforces, GitHub & more. Auto-commits every solve to your GitHub repo.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://github.com/*",
    "https://www.hackerrank.com/*",
    "https://www.codechef.com/*",
    "https://atcoder.jp/*",
    "https://www.geeksforgeeks.org/*",
    "https://api.github.com/*",
    "https://github.com/login/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://codeforces.com/*",
        "https://github.com/*",
        "https://www.hackerrank.com/*",
        "https://www.codechef.com/*",
        "https://atcoder.jp/*",
        "https://www.geeksforgeeks.org/*"
      ],
      "js": ["injected-detector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "https://codeforces.com/*",
        "https://github.com/*",
        "https://www.hackerrank.com/*",
        "https://www.codechef.com/*",
        "https://atcoder.jp/*",
        "https://www.geeksforgeeks.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeMerge",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
